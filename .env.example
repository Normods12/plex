# ==============================================================================
# PLEXONICS WEB PLATFORM - SHARED ENVIRONMENT CONFIGURATION TEMPLATE
# ==============================================================================
# Copy this file to '.env' and populate with your configuration.
# DO NOT commit the actual '.env' file to your version control repository!

# ── DATABASE CONFIGURATION ───────────────────────────────────────────────────
# SQLite local backup fallback is used by default if URL is commented out.
# DATABASE_URL=postgres://<username>:<password>@<host>:<port>/<database_name>
DATABASE_SSL=false

# ── STRAPI SECURITY SALTS & SECRETS ───────────────────────────────────────────
# Generate unique 32-character random values for production.
# You can use: openssl rand -base64 32 or any strong random salt generator.
APP_KEYS=placeholder_app_key_1,placeholder_app_key_2,placeholder_app_key_3,placeholder_app_key_4
API_TOKEN_SALT=placeholder_api_token_salt_value_here
ADMIN_JWT_SECRET=placeholder_admin_jwt_secret_value_here
TRANSFER_TOKEN_SALT=placeholder_transfer_token_salt_value_here
JWT_SECRET=placeholder_jwt_secret_value_here

# ── SERVICE CONFIGURATION ─────────────────────────────────────────────────────
NODE_ENV=development
HOST=0.0.0.0
PORT=1337
PUBLIC_URL=http://localhost:1337

# ── FRONTEND INTEGRATION ──────────────────────────────────────────────────────
NEXT_PUBLIC_STRAPI_URL=http://localhost:1337
FRONTEND_URL=http://localhost:3000

# Generated Strapi API token for frontend reads. Get this from the admin panel
# under Settings > API Tokens (with read-only permissions for Products, etc.)
STRAPI_API_TOKEN=your_read_only_strapi_api_token_here

# ── SEARCH ENGINE OPTIMIZATION (SEO) ──────────────────────────────────────────
SITE_NAME=Plexonics
