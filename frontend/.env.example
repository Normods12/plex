# Strapi backend URL (public, used in browser)
NEXT_PUBLIC_STRAPI_URL=http://localhost:1337

# Strapi API token for server-side requests
STRAPI_API_TOKEN=your_frontend_read_token_here

# Public site URL (for metadata)
NEXT_PUBLIC_SITE_URL=https://www.plexonics.com

# SMTP configuration (for contact form and product registration emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_user@gmail.com
SMTP_PASS=your_smtp_app_password

# Contact form recipient
CONTACT_EMAIL=info@plexonics.com

# hCaptcha (https://dashboard.hcaptcha.com)
# Use "10000000-ffff-ffff-ffff-000000000001" as site key for local testing
# Use "0x0000000000000000000000000000000000000000" as secret key for local testing
NEXT_PUBLIC_HCAPTCHA_SITE_KEY=10000000-ffff-ffff-ffff-000000000001
HCAPTCHA_SECRET_KEY=0x0000000000000000000000000000000000000000
